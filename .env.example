# Fyers API Configuration (Optional - if not set, will fall back to yfinance)
# Get your credentials from https://www.fyers.in/data-api/

# Python executable for the background API job runner.
# Point this to the interpreter or virtualenv that has numpy/pandas/yfinance installed.
# Example:
# PROJECT_PYTHON=C:\Users\Hemant\AppData\Local\Programs\Python\Python313\python.exe
PROJECT_PYTHON=

# Your Fyers App ID
FYERS_API_KEY=your_fyers_api_key_here

# Your Fyers Access Token (obtained after OAuth/login flow)
FYERS_ACCESS_TOKEN=your_fyers_access_token_here
